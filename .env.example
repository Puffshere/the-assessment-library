# Base URL prefix for assessment cover images. Defaults to the direct
# Backblaze B2 public URL if unset:
#   https://f004.backblazeb2.com/file/library-assessments
# In production, set this to the Cloudflare-fronted CDN host so new
# uploads return cached URLs and bandwidth is billed to Cloudflare
# (free via the Bandwidth Alliance) instead of B2's daily egress cap.
# To roll back the CDN, run `heroku config:unset IMAGE_CDN_URL`.
IMAGE_CDN_URL=https://cdn.theassessmentlibrary.com
